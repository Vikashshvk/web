<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora post</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        *{
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}
body{
    background-color: rgb(222, 222, 255);
}

.container{
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
}
.post{
    text-align: center;
    max-height: 500px;
    width: 300px;
    margin: 10px;
    background-color: rgba(241, 186, 113, 0.969);
    padding: 10px;
    border-radius: 10px;
    transition: all 0.3s ease-in-out;  
    box-shadow: 1px 10px 10px  rgba(197, 144, 74, 0.969);
    overflow-y: auto;
}
.post::-webkit-scrollbar{
    height: 15px;
    width: 15px;
}
.post::-webkit-scrollbar-thumb{
    background:#21b2d384;
    border-radius: 10px;
    transition: all .8s ease-in-out;
    cursor: pointer;
}
.post::-webkit-scrollbar-thumb:hover{
    background: rgb(212, 141, 0);
}



h1{
    color: red;
}
.heading{
    color: rgb(16, 143, 202);
    font-weight: 800;
    font-size: 30px;
    
}

#text-type {
    background-color: rgb(212, 141, 0);
    color: white;
    width: 350px;
    height: 200px;
    border-radius: 10px;
    padding: 20px;
    padding-left:  40px;
    padding-right: 40px;
    margin: 5px;
    position: relative;
    left: 5px;
    font-size: 20px;
    font-weight: 500;   
}

#upload{
    position: static;
    top: 70%;
    left: 50%;
    background-color: blueviolet;
    color: white;
    padding: 10px;
    border-radius: 10px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.8s ease-in-out;
    box-shadow: 1px 10px 10px  rgba(8, 7, 9, 0.68);
}
#upload:hover{
    box-shadow: 1px 10px 10px  rgba(137, 43, 226, 0.68);
}



#detail{
    text-decoration: none;
    color: rgb(6, 141, 6);
    font-weight: 500;
}
.a1{
   
    position: relative;
    right: 50px;
}
.a2{
    position: relative;
    left: 50px;
}

input{
    margin-top: 40px;
    height: 40px;
    width: 300px;
    border-radius: 10px;
    background: transparent;
    padding-left: 10px;
    border: 2px solid;
    font-size: 15px;
    outline: none;
    font-weight: 500;;
}

.btn{
    padding: 2px;
    width: 70px;
    border-radius: 10px;
    border: 2px solid rgb(205, 50, 50); /* Shuru se border rakhein taaki layout na hile */
    background-color: rgb(255, 0, 0);
    transition: all 0.3s ease; 
    cursor: pointer;
    font-weight: 500;
    outline: none;
    color: white;
    height: 40px;
    
}


.btn:active{
    background-color:red;
    border: 2px solid rgb(205, 50, 50);
}

.logo{
    text-align: center;
    font-weight: 800;
}
    </style>
    
</head>
<body>
    <h1 class="logo" >Shubham Electric Sell and Service </h1>
    <div class="container" >
        <% for(let post of posts) { %>
            <div class="post">
               <h3 class="heading" ><%=post.username%> </h3> 
               <hr>
               <h3>  <%=post.content%> </h3>  
               <a id="detail" class="a1" href="http://localhost:8080/posts/<%=post.id%>">See in details</a>
               <a id="detail" class="a2"  href="http://localhost:8080/posts/<%=post.id%>/edit">Edit posts</a>
            </div>    
            <form  method="post" action="/posts/<%=post.id%>?_method=DELETE" method="post">
               <button class="btn">delete</button>
               </form>   
        <% } %>
        <a  id="upload" href="http://localhost:8080/posts/new">Upload new post</a> 
    </div>
</body>
</html>