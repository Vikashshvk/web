<% layout("/layouts/boilerplate") %>
<body>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-2">
  <% for(let post of posts) { %>
    <div class="col">
      <div class="card h-100 listing-card shadow-sm">
        
        <img src="<%= post.image.url %>" class="card-img-top pic " alt="Post Image" style="height: 13rem; object-fit: cover;">
        
        <div class="card-body d-flex flex-column">
          <h5 class="card-title text-primary">@<%= post.username %></h5>
          <hr>
          
          <p class="card-text flex-grow-1 text-muted">
            <%= post.description %>
          </p>
          
          <div class="mt-3 d-flex justify-content-between align-items-center">
            <a class="btn btn-sm btn-outline-primary" href="/posts/<%= post._id %>">See Details</a>
            <a class="btn btn-sm btn-outline-secondary" href="/posts/<%= post._id %>/edit">Edit</a>
            
            <form method="POST" action="/posts/<%= post._id %>?_method=DELETE" class="d-inline">
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>

        </div>
      </div>
    </div>
  <% } %>
</div>

<div class="text-center my-5">
  
</div>
</body>

 


